<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      styleClass="stats-panel" spacing="10" prefWidth="280">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <!-- Header -->
    <Label fx:id="panelTitleLabel" text="📊 HR Statistics" styleClass="stats-header">
        <style>
            -fx-font-weight: bold;
            -fx-font-size: 14px;
        </style>
    </Label>

    <HBox fx:id="dashboardLegendRow" spacing="10">
        <Label text="Current dashboard:" styleClass="stats-label"/>
        <Label fx:id="tagLegendLabel" text="Tag" styleClass="stats-label"/>
        <Label fx:id="deptLegendLabel" text="Dept" styleClass="stats-label"/>
    </HBox>

    <!-- Separator line -->
    <Region fx:id="topSeparator" styleClass="separator-line" prefHeight="1"/>

    <!-- Statistics -->
    <VBox fx:id="statisticsSection" spacing="8">
        <HBox spacing="10">
            <Label text="👥 Total employees:" styleClass="stats-label" prefWidth="140"/>
            <Label fx:id="totalEmployeesLabel" styleClass="stats-value"/>
        </HBox>

        <HBox spacing="10">
            <Label fx:id="uniqueMetricTextLabel" text="🏷️ Unique tags:" styleClass="stats-label" prefWidth="140"/>
            <Label fx:id="uniqueTagsLabel" styleClass="stats-value"/>
        </HBox>

        <HBox spacing="10">
            <Label fx:id="mostCommonMetricTextLabel" text="📈 Most common tag:" styleClass="stats-label" prefWidth="140"/>
            <Label fx:id="mostCommonTagLabel" styleClass="stats-value"/>
        </HBox>

        <HBox spacing="10" fx:id="employeesWithRow">
            <Label fx:id="employeesWithMetricTextLabel" text="✅ Employees with tags:" styleClass="stats-label"
                   prefWidth="140"/>
            <Label fx:id="employeesWithTagsLabel" styleClass="stats-value"/>
        </HBox>

        <HBox spacing="10" fx:id="employeesWithoutRow">
            <Label fx:id="employeesWithoutMetricTextLabel" text="❌ Without tags:" styleClass="stats-label"
                   prefWidth="140"/>
            <Label fx:id="employeesWithoutTagsLabel" styleClass="stats-value"/>
        </HBox>
    </VBox>

    <Region fx:id="bottomSeparator" styleClass="separator-line" prefHeight="1"/>

    <Label fx:id="distributionHeaderLabel" text="📋 Tag Distribution (Top 5)" styleClass="stats-label"/>
    <Label fx:id="tagDistributionLabel" styleClass="tag-distribution" wrapText="true"/>

    <!-- Department list override -->
    <VBox fx:id="departmentListSection" spacing="8" visible="false" managed="false">
        <Label text="All departments (Top 30)" styleClass="stats-label"/>
        <Label fx:id="departmentListLabel" styleClass="tag-distribution" wrapText="true"/>
    </VBox>

</VBox>
